{
  "ReverseProxy": {
    "Clusters": {
      "auth-cluster": {
        "Destinations": { "dest1": { "Address": "http://localhost:8080/api/" } }
      },
      "order-cluster": {
        "Destinations": { "dest1": { "Address": "http://localhost:8081/api/" } }
      },
      "payment-cluster": {
        "Destinations": { "dest1": { "Address": "http://localhost:8082/api/" } }
      }
    }
  },
  "Jwt": {
    "SecretKey": "default-local-test-key-1234567890",
    "Issuer": "msa-auth-service",
    "Audience": "msa-gateway"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Yarp": "Debug"
    }
  }
}
