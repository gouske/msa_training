{
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/auth/{**remainder}" },
        "AuthorizationPolicy": "Anonymous"
      },
      "order-route": {
        "ClusterId": "order-cluster",
        "Match": { "Path": "/order/{**remainder}" },
        "AuthorizationPolicy": "default"
      },
      "payment-route": {
        "ClusterId": "payment-cluster",
        "Match": { "Path": "/payment/{**remainder}" },
        "AuthorizationPolicy": "default"
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": { "dest1": { "Address": "http://auth-service:8080/api/" } }
      },
      "order-cluster": {
        "Destinations": { "dest1": { "Address": "http://order-service:8081/api/" } }
      },
      "payment-cluster": {
        "Destinations": { "dest1": { "Address": "http://payment-service:8082/api/" } }
      }
    }
  },
  "Jwt": {
    "SecretKey": "default-local-test-key-1234567890",
    "Issuer": "msa-auth-service",
    "Audience": "msa-gateway"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
