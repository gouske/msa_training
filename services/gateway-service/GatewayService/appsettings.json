{
  "Kestrel": {
    "Endpoints": {
      "Public": {
        "Url": "http://0.0.0.0:9000"
      },
      "Management": {
        "_comment": "[Codex Phase 2 review #1] /metrics 전용 내부 포트. docker-compose 에서 호스트 포트 노출 안 함 → Prometheus 컨테이너만 도달 가능.",
        "Url": "http://0.0.0.0:9091"
      }
    }
  },
  "Metrics": {
    "_comment": "[Codex Phase 2 review #1] /metrics 가 매핑되는 호스트(:포트). RequireHost 매칭으로 Public(9000) 에는 노출되지 않는다.",
    "ManagementHost": "*:9091"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-service",
        "Match": { "Path": "/auth/{**remainder}" },
        "AuthorizationPolicy": "Anonymous"
      },
      "order-route": {
        "ClusterId": "order-service",
        "Match": { "Path": "/order/{**remainder}" },
        "AuthorizationPolicy": "default"
      },
      "payment-route": {
        "ClusterId": "payment-service",
        "Match": { "Path": "/payment/{**remainder}" },
        "AuthorizationPolicy": "default"
      }
    }
  },
  "Consul": {
    "Address": "http://localhost:8500",
    "Services": ["auth-service", "order-service", "payment-service"],
    "PollIntervalSeconds": 5
  },
  "Jwt": {
    "SecretKey": "default-local-test-key-1234567890",
    "Issuer": "msa-auth-service",
    "Audience": "msa-gateway"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
