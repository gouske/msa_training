{
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/auth/{**remainder}" }
      },
      "order-route": {
        "ClusterId": "order-cluster",
        "Match": { "Path": "/order/{**remainder}" }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": { "dest1": { "Address": "http://localhost:8080/api/" } }
      },
      "order-cluster": {
        "Destinations": { "dest1": { "Address": "http://localhost:8081/api/" } }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
