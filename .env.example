# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# MSA Training 환경 변수 템플릿
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 사용법:
#   1. 이 파일을 .env로 복사합니다: cp .env.example .env
#   2. 값을 환경에 맞게 수정합니다
#   3. docker-compose가 .env를 자동으로 읽습니다
#
# .env 파일은 .gitignore에 포함되어 있어 커밋되지 않습니다.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# JWT 비밀 키 — Auth Service(토큰 발급)와 Gateway(토큰 검증)가 공유합니다.
# 운영 환경에서는 반드시 강력한 랜덤 키로 교체하세요.
JWT_SECRET_KEY=default-local-test-key-1234567890

# 서비스 간 통신용 내부 API 키 — Order Service와 Payment Service가 공유합니다.
# Payment Service가 콜백 호출 시 X-Internal-Key 헤더에 이 값을 포함합니다.
INTERNAL_API_KEY=msa-training-internal-key-2026

# [제24강] Grafana 관리자 자격 — 운영에서는 반드시 강력한 비밀번호로 교체.
# admin/admin 기본값은 학습 시작용일 뿐, 공유 호스트 / VM / CI 러너에서는 노출 위험이 큼.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
